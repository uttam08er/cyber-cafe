FLASK_ENV=development

SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-min-32-chars

# PostgreSQL
# DATABASE_URL=postgresql://username:password@localhost:5432/cybercafe
DATABASE_URL=sqlite:///cybercafe.db


# ── PostgreSQL ────────────────────────────────────────────────
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=cybercafe_user
# POSTGRES_PASSWORD=YourStrongPassword
# POSTGRES_DB=cybercafe_db

# Cloud providers (takes priority over above):
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/db

# ── Email / SMTP (for OTP password reset) ────────────────────
# Gmail: enable "App Passwords" in your Google account settings
#        (2FA required), then paste the 16-char app password below.

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=example@gmail.com
MAIL_PASSWORD=key
MAIL_SENDER=example@gmail.com
MAIL_SENDER_NAME=Shaurya eServices

# Outlook / Hotmail:
# MAIL_SERVER=smtp.office365.com
# MAIL_PORT=587

# Custom SMTP (cPanel, etc.):
# MAIL_SERVER=mail.yourdomain.com
# MAIL_PORT=465
# MAIL_USE_TLS=false

UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

FRONTEND_URL=http://localhost:5173

ADMIN_EMAIL=admin@cybercafe.com
ADMIN_PASSWORD=Admin@123456
